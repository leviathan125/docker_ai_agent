{
    "$schema": "https://railway.com/railway.shema.json",
    "build":{
        "builder": "dockerfile",
        "dockerfilePath": "backend/Dockerfile"},
        "watchPatterns": ["src/**",
                          "requirements.txt",
                          "railway.json",
                          "Dockerfile"],
    "deploy": {
        "startCommand": "uvicorn main:app --host 0.0.0.0 --port 8000"
    }
}